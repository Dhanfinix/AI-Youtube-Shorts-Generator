# ==========================================
# AI YouTube Shorts Generator Environment
# ==========================================

# ------------------------------
# Core AI Authentication (Required)
# ------------------------------
# Your official Gemini API Key. Get one from https://aistudio.google.com
GEMINI_API_KEY=your_api_key_here

# ------------------------------
# Gemini Model Tuning
# ------------------------------
# Primary model to attempt first
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated list of models to cascade through if primary returns 503 or 429
GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite-preview,gemini-2.5-flash,gemma-4-31b-it

# ------------------------------
# Pipeline Preferences
# ------------------------------
# Order of transcription operations.
# Options: [youtube, gemini]
# 'youtube' fetches existing subtitles instantly (free). 
# 'gemini' uploads audio to cloud for high-quality multimodal synthesis (fallback).
LOCAL_TRANSCRIBER_PRIORITY=youtube

# Language hint for translation/transcription
# Options: [auto, id, en, es, etc...]
LOCAL_TARGET_LANGUAGE=auto

# Global output repository path
LOCAL_OUTPUT_DIR=output

# ------------------------------
# Video Intelligence & Face Tracking
# ------------------------------
# Intelligence engine for detecting human speakers in frames.
# Options: [mediapipe, mediapipe-mesh, opencv-haar]
# 'mediapipe-mesh' provides maximum accuracy for speaker tracking.
LOCAL_FACE_DETECTOR=mediapipe-mesh

# Performance acceleration toggle
# Options: [true, false]
USE_GPU=true

# Freeze tracking camera bounds on specific active regions (prevents erratic whipping)
USE_SHOT_LOCK=false

# Enable cinematic vertical cropping with smooth automated zooms on speakers
ENABLE_DYNAMIC_ZOOM=true

# Minimal duration in frames that a dynamic shot must last before switching focus
MIN_SHOT_DURATION=90

# ------------------------------
# Subtitle Stylization
# ------------------------------
# Enable gorgeous CapCut-style word-by-word dynamic highlighting captions.
# Replaces generic static text with high-quality animated viral-ready subtitles.
USE_ASS_SUBTITLES=true

# ------------------------------
# Network / Scraping
# ------------------------------
# Optional proxy endpoint for yt-dlp if encountering rate blocks locally
# Example: http://user:pass@host:port
YOUTUBE_PROXY=
